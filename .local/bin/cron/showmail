#! /usr/bin/sh
export DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
new=$(find $HOME/.local/share/mail/*/INBOX/new -type f -newer $HOME/.local/share/mail/showmaillastrun)
newcount=$(echo "$new" | sed '/^\s*$/d' | wc -l)
if [ "$newcount" -gt "0" ]; then
        for file in $new; do
		from=$(grep "From:" $new | sed "s/</\&lt;/" | sed "s/>/\&gt\;/")
		# Extract subject and sender from mail.
		subject=$(grep "^Subject:" $new)
		to=$(grep "^To:" $new | rev | awk '{print $1}' | rev | grep -o -P '(?<=@).*(?=\.)' | sed 's/.*/\u&/')
		notify-send  "New Mail in $to! ﯬ" "$from\n$subject" &
	done
fi

touch $HOME/.local/share/mail/showmaillastrun
