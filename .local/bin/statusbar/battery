#!/usr/bin/env sh

# Prints current information for all batteries on the system
case $BLOCK_BUTTON in
	6) "$TERMINAL" -e "$EDITOR" "$0" ;;
esac


# Loop through all batteries in the information dir
for battery in /sys/class/power_supply/BAT?; do
	# Get the capaciy and the stat
	capacity=$(cat "$battery"/capacity)
	stat=$(cat "$battery"/status)

	if [ "$capacity" -ge 85 ]; then
		icon="п‰Ђ"
	elif [ "$capacity" -ge 65 ]; then
		icon="п‰Ѓ"
	elif [ "$capacity" -ge 40 ]; then
		icon="п‰‚"
	elif [ "$capacity" -ge 15 ]; then
		icon="п‰ѓ"
	else
		icon="п‰„"
		warn=" п„Є"
	fi

	[ -z $warn ] && warn=" "


	# printf "^b$(xgetres slstatus.color14)^"
	# printf "^c$(xgetres slstatus.background)^"
	printf " %s%s%s " "$(echo "$stat" | sed -e "s/,//;s/Discharging/$icon /;s/Not charging/пЉЌ/;s/Charging/п‡¦/;s/Unknown/п†ё/;s/Full/пѓ§/;s/ 0*/ /g;s/ :/ /g")" "$warn" "$(echo "$capacity" | sed -e 's/$/%/')"
	unset warn
done
