#!/usr/bin/env bash

case $BLOCK_BUTTON in
	1) setsid "$TERMINAL" -e pulsemixer & ;;
	2) notify-send " Volume Module" "\- Scroll: change volume\n\- Right click: toggle mute\n\- Left click: Launch pulsemixer" ;;
	3) lmc toggle && pkill -RTMIN+12 dwmblocks ;;
	4) lmc up 5 && pkill -RTMIN+12 dwmblocks;;
	5) lmc down 5 && pkill -RTMIN+12 dwmblocks;;
	6) "$TERMINAL" -e "$EDITOR" "$0" ;;
esac



volstat="$(pactl list sinks)"
# volstat="$(amixer get Master)" # ALSA only equivalent.

# printf "^b$(xgetres slstatus.color9)^"
# printf "^c$(xgetres slstatus.background)^"
echo "$volstat" | grep -q "Mute: yes" && printf " ﱝ MUTE \\n" && exit
# echo "$volstat" | grep "\[off\]" >/dev/null && printf "🔇\\n" && exit # ALSA

vol="$(echo "$volstat" | grep '^[[:space:]]Volume:' | sed "s,.* \([0-9]\+\)%.*,\1,;1q")"
# vol=$(echo "$volstat" | grep -o "\[[0-9]\+%\]" | sed "s/[^0-9]*//g;1q") # ALSA

if [ "$vol" -gt "70" ]; then
	icon=""
elif [ "$vol" -lt "30" ]; then
	icon=""
else
	icon=""
fi

printf " %s %s%% \\n" "$icon" "$vol"
