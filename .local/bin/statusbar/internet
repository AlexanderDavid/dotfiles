#!/usr/bin/env sh

[ "$(cat /sys/class/net/w*/operstate)" = 'down' ] && wifiicon=""

[ ! -n "${wifiicon+var}" ] && wifiicon=$(grep "^\s*w" /proc/net/wireless | awk '{ print "", sprintf("%s", int($3 * 100 / 70)) "%" }')

# printf "^b$(xgetres slstatus.color5)^"
# printf "^c$(xgetres slstatus.background)^"
printf " %s " "$wifiicon" # "$(cat /sys/class/net/w*/operstate | sed "s/down/⬇/;s/up//")"


case $BLOCK_BUTTON in
	1) $TERMINAL -e nmtui ;;
	2) pgrep -x dunst >/dev/null && notify-send " Internet module" "\- Right click: show current WAP\n\- Left click: Open nmtui" ;;
	3) pgrep -x dunst >/dev/null && notify-send " Network Information" "Current WAP SSID: $(nmcli -t -f active,ssid dev wifi | grep '^yes' | cut -d\: -f2) \nCurrent local IP: $(ip a | grep -E "inet.*wlp2s0" | awk '{print $2}' | sed 's/\/24//')" ;;
	6) "$TERMINAL" -e "$EDITOR" "$0" ;;
esac
